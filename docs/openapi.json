{
  "openapi": "3.1.0",
  "info": {
    "title": "skeleton-web API",
    "description": "\nAPI for the **skeleton-web** template.\n\n## Default admin credentials\n- **Username**: `admin`\n- **Password**: `changeme` \u2014 **change in production** via `ADMIN_PASSWORD` in `.env`\n\n## Patterns demonstrated\n- Simple FK (User \u2192 Role)\n- Many-to-many (Role \u2194 Permission) with association table\n- Two-level nested response (User \u2192 Role \u2192 [Permission])\n\n## Authentication\nNot implemented in this template. Add JWT / OAuth2 as a next step.\n    ",
    "contact": {
      "name": "skeleton-web",
      "url": "https://github.com/manzolo/skeleton-web"
    },
    "license": {
      "name": "MIT"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/permissions/": {
      "get": {
        "tags": [
          "permissions"
        ],
        "summary": "List Permissions",
        "description": "Return all permissions registered in the system.",
        "operationId": "list_permissions_permissions__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/PermissionRead"
                  },
                  "type": "array",
                  "title": "Response List Permissions Permissions  Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "permissions"
        ],
        "summary": "Create Permission",
        "description": "Create a new permission. The codename must be unique (e.g. 'articles.edit').",
        "operationId": "create_permission_permissions__post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PermissionCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PermissionRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/roles/": {
      "get": {
        "tags": [
          "roles"
        ],
        "summary": "List Roles",
        "description": "Return all roles with their assigned permissions.",
        "operationId": "list_roles_roles__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/RoleRead"
                  },
                  "type": "array",
                  "title": "Response List Roles Roles  Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "roles"
        ],
        "summary": "Create Role",
        "description": "Create a new role. Name and slug must be unique.",
        "operationId": "create_role_roles__post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RoleCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoleRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/roles/{role_id}/permissions/{permission_id}": {
      "post": {
        "tags": [
          "roles"
        ],
        "summary": "Assign Permission",
        "description": "Assign an existing permission to a role. Idempotent: safe to call multiple times.",
        "operationId": "assign_permission_roles__role_id__permissions__permission_id__post",
        "parameters": [
          {
            "name": "role_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Role Id"
            }
          },
          {
            "name": "permission_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Permission Id"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/users/": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "List Users",
        "description": "Return all users with their role and permissions.",
        "operationId": "list_users_users__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/UserRead"
                  },
                  "type": "array",
                  "title": "Response List Users Users  Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "users"
        ],
        "summary": "Create User",
        "description": "Create a new user. Email and username must be unique. Password is hashed before storage.",
        "operationId": "create_user_users__post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/users/{user_id}": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "Get User",
        "description": "Return a single user with role and permissions. 404 if not found.",
        "operationId": "get_user_users__user_id__get",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "User Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Health",
        "description": "Check API and database connectivity.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PermissionCreate": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Human-readable permission name",
            "example": "Can edit articles"
          },
          "codename": {
            "type": "string",
            "title": "Codename",
            "description": "Unique identifier in slug.action format",
            "example": "articles.edit"
          }
        },
        "type": "object",
        "required": [
          "name",
          "codename"
        ],
        "title": "PermissionCreate"
      },
      "PermissionRead": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "codename": {
            "type": "string",
            "title": "Codename"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "codename"
        ],
        "title": "PermissionRead"
      },
      "RoleCreate": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Role display name",
            "example": "Editor"
          },
          "slug": {
            "type": "string",
            "title": "Slug",
            "description": "URL-safe unique identifier",
            "example": "editor"
          }
        },
        "type": "object",
        "required": [
          "name",
          "slug"
        ],
        "title": "RoleCreate"
      },
      "RoleRead": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "slug": {
            "type": "string",
            "title": "Slug"
          },
          "permissions": {
            "items": {
              "$ref": "#/components/schemas/PermissionRead"
            },
            "type": "array",
            "title": "Permissions",
            "description": "Permissions assigned to this role",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "slug"
        ],
        "title": "RoleRead"
      },
      "UserCreate": {
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email",
            "description": "Unique email address",
            "example": "alice@example.com"
          },
          "username": {
            "type": "string",
            "title": "Username",
            "description": "Unique username",
            "example": "alice"
          },
          "password": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Password",
            "description": "Plain-text password \u2014 will be hashed before storage"
          },
          "role_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Role Id",
            "description": "Role ID to assign (optional)"
          }
        },
        "type": "object",
        "required": [
          "email",
          "username"
        ],
        "title": "UserCreate"
      },
      "UserRead": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "email": {
            "type": "string",
            "title": "Email"
          },
          "username": {
            "type": "string",
            "title": "Username"
          },
          "is_active": {
            "type": "boolean",
            "title": "Is Active"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "role": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/RoleRead"
              },
              {
                "type": "null"
              }
            ],
            "description": "Role with permissions, null if not assigned"
          }
        },
        "type": "object",
        "required": [
          "id",
          "email",
          "username",
          "is_active",
          "created_at",
          "role"
        ],
        "title": "UserRead"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
